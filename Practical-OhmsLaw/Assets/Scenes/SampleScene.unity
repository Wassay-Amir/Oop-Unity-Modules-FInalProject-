  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "EXPERIMENT 14.1: VERIFY OHM'S LAW\r\n\r\nPROCEDURE:\r\n1. Arrange the
    Nichrome wire on the Experiment Table\r\n2. Connect the circuit as shown:\r\n  
    - Connect Power Supply positive to Ammeter\r\n   - Connect Ammeter to Nichrome
    Wire\r\n   - Connect Nichrome Wire to Voltmeter\r\n   - Connect Voltmeter back
    to Power Supply negative\r\n3. Turn ON the Power Supply\r\n4. Adjust the Rheostat
    to vary resistance\r\n5. Record Voltmeter (V) and Ammeter (I) readings\r\n6.
    Repeat 5 times with different rheostat values\r\n7. Calculate R = V/I for each
    reading\r\n8. Verify: V = IR (Ohm's Law)\r\n\r\nREMEMBER:\r\n- Ammeter measures
    current (in series)\r\n- Voltmeter measures voltage (in parallel)\r\n- Keep rheostat
    slider in middle position"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
